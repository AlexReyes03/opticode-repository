SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Opciones: development | production
DJANGO_ENV=development

DB_NAME=opticode_db
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT: True activa autenticación, False desactiva toda autenticación (solo desarrollo)
JWT_ENABLED=True

LOG_LEVEL=DEBUG
LOG_DIR=logs

# Credenciales de desarrollo (seeds y superusuario)
DEV_ADMIN_EMAIL=ejemplo@opticode.com
DEV_ADMIN_USERNAME=TuUsuarioEjemplo
DEV_SEED_PASSWORD=EjemploDEContraseñaSegura123!
