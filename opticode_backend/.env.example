SECRET_KEY=cambia-por-una-clave-secreta-larga-y-aleatoria
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ENV=development
DB_NAME=opticode_db
DB_USER=usuario-mysql-ejemplo
DB_PASSWORD=contrasena-mysql-ejemplo
DB_HOST=127.0.0.1
DB_PORT=3306
CORS_ALLOWED_ORIGINS=http://localhost:5173
JWT_ENABLED=True
# RSA: pon aquí solo la ruta al .pem (relativa a opticode_backend o absoluta). Ej. tras `openssl genrsa -out auth_rsa.pem 2048`:
#   AUTH_RSA_PRIVATE_KEY_FILE=auth_rsa.pem
# Deja vacío para no usar cifrado (login con contraseña en claro en dev). Si defines ruta, el archivo debe existir.
AUTH_RSA_PRIVATE_KEY_FILE=
# Alternativa: PEM en una línea (solo si no usas AUTH_RSA_PRIVATE_KEY_FILE).
AUTH_RSA_PRIVATE_KEY=
AUTH_RSA_KEY_ID=v1
LOG_LEVEL=DEBUG
LOG_DIR=logs
DEV_ADMIN_EMAIL=correo@ejemplo.com
DEV_ADMIN_USERNAME=usuario-ejemplo
DEV_SEED_PASSWORD=ContraseñaDeEjemploSegura123!
