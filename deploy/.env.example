# ============================================================
# deploy/.env.example — Variables para despliegue con Docker
# Copiar como: deploy/.env  (nunca commitear el .env real)
#
# Este archivo es cargado automáticamente por Docker Compose.
# Para desarrollo local sin Docker usa opticode_backend/.env
# ============================================================

# ── Django ───────────────────────────────────────────────────
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

DJANGO_ENV=production
ALLOWED_HOSTS=TU_IP_PUBLICA_EC2
JWT_ENABLED=True

# ── Base de datos (RDS) ──────────────────────────────────────
DB_NAME=opticode
DB_USER=admin
DB_PASSWORD=TU_PASSWORD_RDS
DB_HOST=TU_ENDPOINT.us-east-1.rds.amazonaws.com
DB_PORT=3306

# ── CORS — URL del frontend en Cloudflare Pages ──────────────
# En producción: tu URL de Cloudflare Pages
# En local con Docker: http://localhost:5173
CORS_ALLOWED_ORIGINS=https://opticode.pages.dev

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=WARNING
LOG_DIR=logs

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_PASSWORD=TU_PASSWORD_GRAFANA

# ── mysqld_exporter — usuario de solo lectura en RDS ─────────
# Crear en RDS:
#   CREATE USER 'prometheus'@'%' IDENTIFIED BY 'password';
#   GRANT PROCESS, REPLICATION CLIENT, SELECT ON *.* TO 'prometheus'@'%';
DATA_SOURCE_NAME=prometheus:TU_PASSWORD_MONITOREO@(TU_ENDPOINT.us-east-1.rds.amazonaws.com:3306)/
